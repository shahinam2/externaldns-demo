# Copy to .env (gitignored) and fill in your real token.
# Used to create the Cloudflare API token Secret for ExternalDNS:
#
#   source .env
#   kubectl create secret generic cloudflare-token -n external-dns \
#     --from-literal=cloudflare_api_token="$CF_API_TOKEN"
#
# Token scopes (Cloudflare dashboard → My Profile → API Tokens):
#   Zone › DNS › Edit   AND   Zone › Zone › Read   on devopsdetours-lab.com
CF_API_TOKEN=your-cloudflare-api-token-here
